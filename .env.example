# =============================================================================
# MaqConnect — variables de entorno
# Copia este archivo a `.env.local` y rellena los valores reales.
# =============================================================================

# ----- Supabase (https://supabase.com/dashboard → Project → Settings → API) -----
# URL pública del proyecto (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Anon public key — expuesta al browser. Las políticas RLS son las que protegen
# los datos, no esta key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...

# Service role key — SECRETA. Bypassa RLS. Sólo se usa en el seed y en código
# server-side confiable. NUNCA la expongas al browser ni la commitees.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR...

# ----- Auth (JWT de la sesión propia de MaqConnect) -----
# Secret largo y aleatorio para firmar los JWT de sesión.
# Generar con: `openssl rand -base64 48`
JWT_SECRET=cambia-este-valor-en-produccion-por-algo-aleatorio-y-largo

# ----- Prisma (opcional — legacy, se mantiene por compatibilidad) -----
# DATABASE_URL="file:./dev.db"
